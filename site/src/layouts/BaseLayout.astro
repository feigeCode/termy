---
import "../styles/global.css";
import Header from "../components/layout/Header";
import Footer from "../components/layout/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Termy — A terminal that goes fast",
  description = "GPU-accelerated terminal emulator built with Rust. Instant startup, minimal memory, runs everywhere.",
} = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/termy_icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@100..900&family=Geist+Mono:wght@100..900&display=swap" rel="stylesheet" />
<script defer src="https://analytics.beer/script.js" data-website-id="e7d3ed1c-80ec-4d81-91f4-79da987aea91"></script>
<script defer data-site-id="f9290160-3f4f-49b7-9fea-682d804bc0d9" data-endpoint="https://cdn.usedatix.com/api/event" data-site-domain="termy.run" src="https://cdn.usedatix.com/script.js"></script>
<noscript><img src="https://cdn.usedatix.com/api/pixel?sid=f9290160-3f4f-49b7-9fea-682d804bc0d9&sd=termy.run" alt="" width="1" height="1" referrerpolicy="no-referrer-when-downgrade" style="position:absolute;top:-9999px;left:-9999px" /></noscript>
<script defer src="https://cdn.usedatix.com/outgoing-links.js"></script>
<script defer src="https://cdn.usedatix.com/interactions.js"></script>
<script defer src="https://cdn.usedatix.com/scroll-depth.js"></script>
<script defer data-site-id="f9290160-3f4f-49b7-9fea-682d804bc0d9" data-endpoint="https://cdn.usedatix.com/api/vitals" data-site-domain="termy.run" src="https://cdn.usedatix.com/vitals.js"></script>
<!-- Optional -->
<script defer src="https://cdn.usedatix.com/error-tracking.js"></script>
  </head>
  <body class="min-h-screen bg-background text-foreground">
    <Header client:load />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
