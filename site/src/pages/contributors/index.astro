---
import BaseLayout from "../../layouts/BaseLayout.astro";

interface Contributor {
  total: number;
  weeks: Array<{ w: number; a: number; d: number; c: number }>;
  author: {
    login: string;
    id: number;
    avatar_url: string;
    html_url: string;
  };
}

let contributors: Contributor[] = [];
try {
  const res = await fetch("https://api.termy.run/api/github/contributors");
  if (res.ok) contributors = await res.json();
  contributors.sort((a, b) => b.total - a.total);
} catch {
  // empty
}
---

<BaseLayout title="Contributors — Termy" description="The people who build Termy.">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 py-12">
    <div class="mb-10">
      <h1 class="text-3xl font-bold tracking-tight">Contributors</h1>
      <p class="mt-2 text-muted-foreground">The people who make Termy possible.</p>
    </div>

    {contributors.length === 0 ? (
      <p class="text-muted-foreground text-sm">Could not load contributors.</p>
    ) : (
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {contributors.map((c, i) => (
          <a
            href={c.author.html_url}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-3 rounded border border-border/50 p-4 transition-colors hover:border-border hover:bg-card/40"
          >
            <img
              src={c.author.avatar_url}
              alt={c.author.login}
              class="h-10 w-10 rounded-full border border-border/50"
              width="40"
              height="40"
            />
            <div class="min-w-0">
              <div class="truncate text-sm font-medium text-foreground">{c.author.login}</div>
              <div class="font-mono text-xs text-muted-foreground/60">{c.total} commits</div>
            </div>
            {i === 0 && (
              <span class="ml-auto text-[10px] font-mono text-primary/60 border border-primary/20 rounded px-1.5 py-0.5">top</span>
            )}
          </a>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
