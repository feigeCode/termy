---
import type { Release } from "../../lib/types";
import DownloadSection from "./DownloadSection";

interface Props {
  release: Release | null;
}

const { release } = Astro.props;
---

<section class="relative mx-auto max-w-6xl px-4 sm:px-6 pt-20 pb-16 lg:pt-28 lg:pb-24">
  <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
    <!-- Left: copy -->
    <div class="animate-blur-in" style="animation-delay: 0ms">
      <div class="mb-4 inline-flex items-center gap-2 rounded border border-border px-2.5 py-1 font-mono text-xs text-muted-foreground">
        <span class="h-1.5 w-1.5 rounded-full bg-primary animate-pulse"></span>
        GPU-accelerated · Built with Rust
      </div>
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.05] mb-5">
        A terminal<br />
        that <span class="text-primary">goes fast.</span>
      </h1>
      <p class="text-base sm:text-lg text-muted-foreground leading-relaxed mb-8 max-w-md">
        Instant startup. Minimal memory. Runs everywhere. Termy is the terminal you reach for when every millisecond counts.
      </p>
      <DownloadSection release={release} client:load />
    </div>

    <!-- Right: terminal mockup -->
    <div class="animate-blur-in hidden lg:block" style="animation-delay: 150ms">
      <div class="terminal-window shadow-2xl shadow-black/50">
        <div class="terminal-titlebar">
          <div class="terminal-dot bg-red-400/50"></div>
          <div class="terminal-dot bg-yellow-400/50"></div>
          <div class="terminal-dot bg-green-400/50"></div>
          <div class="ml-3 flex gap-4 text-[11px] font-mono text-muted-foreground/60">
            <span class="text-primary/70 border-b border-primary/30 pb-px">zsh</span>
            <span>vim</span>
            <span>node</span>
          </div>
          <div class="ml-auto text-[10px] text-muted-foreground/30 font-mono">termy v{release?.tag_name ?? "latest"}</div>
        </div>
        <div class="p-4 font-mono text-xs leading-relaxed">
          <div class="flex">
            <div class="flex-1 pr-3 border-r border-border/30 space-y-1.5 text-muted-foreground/60">
              <div><span class="text-primary/60">~</span> cargo build --release</div>
              <div class="text-muted-foreground/30 pl-2">   Compiling termy v0.1.64</div>
              <div class="text-muted-foreground/30 pl-2">   Compiling renderer v0.3.1</div>
              <div class="text-primary/40 pl-2">   Finished in 2.4s ✓</div>
              <div class="mt-3"><span class="text-primary/60">~</span> ./target/release/termy</div>
              <div class="text-primary/50 pl-2 animate-pulse">█</div>
            </div>
            <div class="flex-1 pl-3 space-y-1.5 text-muted-foreground/60">
              <div><span class="text-primary/60">~</span> git log --oneline -5</div>
              <div class="text-muted-foreground/30 pl-2 text-[10px]">a1b2c3d perf: gpu renderer</div>
              <div class="text-muted-foreground/30 pl-2 text-[10px]">e4f5g6h feat: tab splits</div>
              <div class="text-muted-foreground/30 pl-2 text-[10px]">b7c8d9e fix: key bindings</div>
              <div class="text-muted-foreground/30 pl-2 text-[10px]">f1a2b3c chore: update deps</div>
              <div class="mt-3"><span class="text-primary/60">~</span> btm</div>
              <div class="space-y-1 pl-2">
                <div class="flex items-center gap-2 text-[10px]">
                  <span class="text-foreground/50 w-10">termy</span>
                  <span class="flex-1 h-1 rounded-full bg-primary/10"><span class="block h-full w-[6%] bg-primary rounded-full"></span></span>
                  <span class="text-primary/60">18MB</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Stats row -->
  <div class="mt-16 grid grid-cols-3 gap-px border border-border rounded overflow-hidden animate-blur-in" style="animation-delay: 300ms">
    {[
      { value: "8ms", label: "startup time" },
      { value: "18MB", label: "memory usage" },
      { value: "100%", label: "written in Rust" },
    ].map((stat) => (
      <div class="bg-card/40 px-6 py-5 text-center">
        <div class="text-2xl font-bold text-foreground font-mono">{stat.value}</div>
        <div class="text-xs text-muted-foreground mt-1 font-mono">{stat.label}</div>
      </div>
    ))}
  </div>
</section>
