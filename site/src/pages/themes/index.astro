---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ThemeStore from "../../components/themes/ThemeStore";
import type { Theme } from "../../lib/theme-store";

let initialThemes: Theme[] = [];
try {
  const res = await fetch("https://api.termy.run/themes");
  if (res.ok) initialThemes = await res.json();
} catch {
  // empty
}
---

<BaseLayout title="Themes — Termy" description="Browse and install community themes for Termy.">
  <ThemeStore initialThemes={initialThemes} client:load />
</BaseLayout>
