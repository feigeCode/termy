---
import BaseLayout from "./BaseLayout.astro";
import DocsSidebar from "../components/docs/DocsSidebar";
import { getCollection } from "astro:content";
import type { CollectionEntry, MarkdownHeading } from "astro:content";

interface Props {
  entry: CollectionEntry<"docs">;
  headings?: MarkdownHeading[];
}

const { entry, headings = [] } = Astro.props;

const allDocs = await getCollection("docs");
const docsData = allDocs.map((d) => ({
  slug: d.id,
  title: d.data.title ?? d.id,
  category: d.data.category,
  order: d.data.order,
}));

const tocHeadings = headings.filter((h) => h.depth <= 3);
---

<BaseLayout title={`${entry.data.title ?? entry.id} — Termy Docs`} description={entry.data.description}>
  <div class="mx-auto max-w-6xl px-4 sm:px-6 py-8">
    <div class="flex gap-8">
      <DocsSidebar docs={docsData} currentSlug={entry.id} client:load />

      <article class="flex-1 min-w-0 prose prose-invert" id="doc-content">
        <slot />
      </article>

      {tocHeadings.length > 1 && (
        <aside class="hidden xl:block w-48 shrink-0">
          <div class="sticky top-[3.5rem] py-6">
            <p class="mb-3 text-[11px] font-semibold uppercase tracking-wider text-muted-foreground/60">On this page</p>
            <nav>
              <ul class="space-y-1">
                {tocHeadings.map((h) => (
                  <li>
                    <a
                      href={"#" + h.slug}
                      class={`block text-xs transition-colors hover:text-foreground ${
                        h.depth === 2
                          ? "text-muted-foreground py-0.5"
                          : "text-muted-foreground/60 py-0.5 pl-3"
                      }`}
                    >
                      {h.text}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </div>
        </aside>
      )}
    </div>
  </div>
</BaseLayout>

<script>
  // Add copy buttons to all code blocks
  document.querySelectorAll("#doc-content pre").forEach((pre) => {
    const wrapper = document.createElement("div");
    wrapper.style.position = "relative";
    pre.parentNode?.insertBefore(wrapper, pre);
    wrapper.appendChild(pre);

    const btn = document.createElement("button");
    btn.textContent = "Copy";
    btn.setAttribute("aria-label", "Copy code");
    btn.style.cssText = `
      position: absolute;
      top: 0.5rem;
      right: 0.5rem;
      padding: 0.2rem 0.6rem;
      font-size: 0.65rem;
      font-family: var(--font-mono);
      background: var(--secondary);
      color: var(--muted-foreground);
      border: 1px solid var(--border);
      border-radius: 0.25rem;
      cursor: pointer;
      transition: color 0.15s;
      z-index: 1;
    `;
    btn.addEventListener("mouseenter", () => (btn.style.color = "var(--foreground)"));
    btn.addEventListener("mouseleave", () => (btn.style.color = "var(--muted-foreground)"));
    btn.addEventListener("click", () => {
      const code = pre.querySelector("code")?.textContent ?? "";
      navigator.clipboard.writeText(code).then(() => {
        btn.textContent = "Copied!";
        btn.style.color = "var(--primary)";
        setTimeout(() => {
          btn.textContent = "Copy";
          btn.style.color = "var(--muted-foreground)";
        }, 2000);
      });
    });

    wrapper.appendChild(btn);
  });
</script>
