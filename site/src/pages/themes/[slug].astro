---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ThemeDetail from "../../components/themes/ThemeDetail";
import type { ThemeWithVersionsResponse } from "../../lib/theme-store";

const { slug } = Astro.params;

let initialData: ThemeWithVersionsResponse | null = null;
try {
  const res = await fetch(`https://api.termy.run/themes/${slug}/versions`);
  if (res.ok) initialData = await res.json();
} catch {
  // null
}

if (!initialData) {
  return Astro.redirect("/themes");
}
---

<BaseLayout title={`${initialData.theme.name} — Termy Themes`} description={initialData.theme.description}>
  <ThemeDetail initialData={initialData} slug={slug!} client:load />
</BaseLayout>
