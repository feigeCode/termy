---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Notra } from "@usenotra/sdk";

interface NotraPost {
  id: string;
  title: string;
  markdown?: string | null;
  createdAt: string;
}

let posts: NotraPost[] = [];
try {
  const notra = new Notra({ bearerAuth: import.meta.env.NOTRA_API_KEY ?? "" });
  const result = await notra.content.listPosts({
    status: "published",
    contentType: "changelog",
    sort: "desc",
    limit: 100,
  });
  posts = (result.posts ?? []) as NotraPost[];
} catch {
  // empty
}

const items = posts.map((post) => ({
  ...post,
  preview: post.markdown
    ?.replace(/#{1,6}\s/g, "")
    .replace(/\*\*/g, "")
    .replace(/`/g, "")
    .trim()
    .slice(0, 180) ?? "",
  date: new Date(post.createdAt).toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  }),
  href: "/releases/" + post.id,
}));
---

<BaseLayout title="Releases — Termy" description="What's new in Termy.">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 py-12">
    <div class="mb-10">
      <h1 class="text-3xl font-bold tracking-tight">Releases</h1>
      <p class="mt-2 text-muted-foreground">What's new in Termy.</p>
    </div>

    {items.length === 0 && (
      <p class="text-muted-foreground text-sm">No releases yet.</p>
    )}

    {items.length > 0 && (
      <div class="relative">
        <div class="absolute left-[7px] top-2 bottom-2 w-px bg-border/40"></div>
        <div class="space-y-0">
          {items.map((item) => (
            <a href={item.href} class="group relative flex gap-6 pb-10 pl-8 no-underline">
              <div class="absolute left-0 top-1.5 h-3.5 w-3.5 rounded-full border-2 border-border bg-background group-hover:border-primary transition-colors"></div>
              <div class="flex-1 min-w-0 rounded border border-border/40 p-5 bg-card/20 transition-colors group-hover:border-border group-hover:bg-card/40">
                <div class="flex items-start justify-between gap-4 mb-2 flex-wrap">
                  <h2 class="text-base font-semibold text-foreground group-hover:text-primary transition-colors leading-tight">
                    {item.title}
                  </h2>
                  <time class="font-mono text-[11px] text-muted-foreground/50">{item.date}</time>
                </div>
                {item.preview && (
                  <p class="text-sm text-muted-foreground/70 leading-relaxed line-clamp-2">
                    {item.preview.length >= 180 ? item.preview + "…" : item.preview}
                  </p>
                )}
                <span class="mt-3 inline-block text-xs text-primary/50 font-mono">Read more →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    <div class="mt-8 flex items-center justify-center gap-2 opacity-40">
      <span class="text-xs text-muted-foreground">Powered by Notra</span>
      <img src="/notra.svg" alt="Notra" class="h-4" />
    </div>
  </div>
</BaseLayout>
