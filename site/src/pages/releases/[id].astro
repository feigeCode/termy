---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Notra } from "@usenotra/sdk";
import { marked } from "marked";

const { id } = Astro.params;

interface NotraPost {
  id: string;
  title: string;
  markdown?: string | null;
  createdAt: string;
}

let post: NotraPost | null = null;
try {
  const notra = new Notra({ bearerAuth: import.meta.env.NOTRA_API_KEY ?? "" });
  const result = await notra.content.getPost({ postId: id! });
  post = result.post as NotraPost ?? null;
} catch {
  // null
}

if (!post) {
  return Astro.redirect("/releases");
}

const html = await marked.parse(post.markdown ?? "");

const date = new Date(post.createdAt).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title={`${post.title} — Termy Releases`} description={post.markdown?.replace(/[#*`]/g, "").trim().slice(0, 160)}>
  <div class="mx-auto max-w-3xl px-4 sm:px-6 py-12">
    <a
      href="/releases"
      class="inline-flex items-center gap-1.5 mb-10 text-sm text-muted-foreground transition-colors hover:text-foreground"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
      All releases
    </a>

    <header class="mb-10">
      <div class="flex items-start justify-between gap-4 flex-wrap">
        <h1 class="text-3xl font-bold tracking-tight leading-tight">{post.title}</h1>
        <time class="font-mono text-sm text-muted-foreground/60 mt-1">{date}</time>
      </div>
    </header>

    <article class="prose prose-invert max-w-none" set:html={html} />

    <div class="mt-12 pt-8 border-t border-border/40 flex items-center justify-center gap-2 opacity-40">
      <span class="text-xs text-muted-foreground">Powered by Notra</span>
      <img src="/notra.svg" alt="Notra" class="h-4" />
    </div>
  </div>
</BaseLayout>
